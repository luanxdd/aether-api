# ── Servidor ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3333

# ── JWT ───────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
JWT_SECRET=coloque_uma_string_longa_e_aleatoria_aqui_minimo_32_chars
JWT_EXPIRES_IN=7d

# ── Admin padrão (criado automaticamente no primeiro boot) ─────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sua_senha

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DOWNLOAD_RATE_LIMIT_MAX=10

# ── Banco de dados ─────────────────────────────────────────────
DATABASE_URL=file:./aether.db

# ── Armazenamento ──────────────────────────────────────────────
DOWNLOADS_DIR=./downloads
MAX_DOWNLOAD_SIZE_MB=150

# ── CORS ───────────────────────────────────────────────────────
# Use * para todas as origens ou liste separadas por vírgula:
# CORS_ORIGINS=https://meusite.com,https://meuapp.com
CORS_ORIGINS=*
